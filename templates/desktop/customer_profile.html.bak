{% extends "desktop/base.html" %}
{% block title %}{{ customer.name }} | {{ tenant.name }}{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4>{{ customer.name }}</h4>
            </div>
            <div class="card-body">
                <p><strong>Phone:</strong> {{ customer.phone|default:"-" }}</p>
                <p><strong>Address:</strong> {{ customer.address|default:"-" }}</p>
                <p><strong>Total Pending:</strong> ₹{{ total_pending|floatformat:2 }}</p>
                <p><strong>Total Orders:</strong> {{ total_orders }}</p>
                <p><strong>Total Spent:</strong> ₹{{ total_spent|floatformat:2 }}</p>
                <a href="/portal/{{ tenant.schema_name }}/chakki/order/add/?customer_id={{ customer.id }}" class="btn btn-primary">+ New Order</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h5>Order History</h5></div>
            <div class="card-body">
                <table class="table table-sm">
                    <thead><tr><th>#ID</th><th>Date</th><th>Total</th><th>Status</th><th>Payment</th></tr></thead>
                    <tbody>
                        {% for order in orders %}
                        <tr>
                            <td>{{ order.id }}</td>
                            <td>{{ order.created_at|date:"d M Y H:i" }}</td>
                            <td>₹{{ order.total_amount }}</td>
                            <td><span class="badge bg-{% if order.status == 'pending' %}secondary{% elif order.status == 'ready' %}warning{% else %}success{% endif %}">{{ order.status|title }}</span></td>
                            <td>{% if order.payment_status == 'partial' %}<span class="badge bg-info">Partial</span>{% else %}{{ order.payment_status|title }}{% endif %}</td>
                        </tr>
                        {% empty %}
                        <tr><td colspan="5" class="text-muted">No orders</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
