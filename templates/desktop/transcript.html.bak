
<!DOCTYPE html>
<html>
<head><title>Transcript - Order #{{ order.id }}</title>
<style>
    body { font-family: Arial, sans-serif; padding: 40px; max-width: 400px; margin: auto; }
    .header { text-align: center; border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 20px; }
    .watermark { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-45deg); font-size: 80px; color: rgba(0,0,0,0.1); pointer-events: none; z-index: 999; }
    .footer { text-align: center; margin-top: 30px; border-top: 1px solid #ccc; padding-top: 10px; }
    table { width: 100%; border-collapse: collapse; }
    td, th { padding: 8px; border: 1px solid #ccc; }
    .right { text-align: right; }
    .print-btn { margin-top: 20px; text-align: center; }
    @media print {
        .no-print { display: none; }
        .watermark { color: rgba(0,0,0,0.05); }
    }
</style>
</head>
<body>
<div class="watermark">
    {% if order.payment_status == 'paid' %}PAID{% elif order.payment_status == 'partial' %}PARTIAL PAID{% else %}UNPAID{% endif %}
</div>
<div class="header">
    <h1>{{ tenant.name }}</h1>
    <p>Flour Mill Invoice</p>
</div>
<h3>Order #{{ order.id }}</h3>
<p><strong>Customer:</strong> {{ order.customer.name }}<br>
<strong>Phone:</strong> {{ order.customer.phone }}<br>
<strong>Address:</strong> {{ order.customer.address }}</p>
<h4>Items</h4>
<table>
    <tr><th>Category</th><th>KG</th><th>Cleaning</th><th>Grinding</th><th>Cleaning Charges</th><th>Total</th></tr>
    {% for item in order.items.all %}
    <tr>
        <td>{{ item.category.name }}</td>
        <td>{{ item.total_kg }}</td>
        <td>{{ item.is_cleaning_done|yesno:"Yes,No" }}</td>
        <td class="right">₹{{ item.grinding_charges }}</td>
        <td class="right">₹{{ item.cleaning_charges }}</td>
        <td class="right">₹{{ item.item_total }}</td>
    </tr>
    {% endfor %}
    <tr><th colspan="5">Grand Total</th><th class="right">₹{{ order.total_amount }}</th></tr>
    <tr><td colspan="5">Amount Paid</td><td class="right">₹{{ order.amount_paid }}</td></tr>
    <tr><td colspan="5">Remaining</td><td class="right">₹{{ order.remaining_amount }}</td></tr>
</table>
<div class="footer">
    <p>Generated on {% now "d M Y H:i" %} | Thank you!</p>
</div>
<div class="print-btn no-print">
    <button onclick="window.print()" class="btn btn-primary">🖨️ Print</button>
    <button onclick="window.downloadPDF()" class="btn btn-secondary">⬇️ Download PDF</button>
</div>
<script>
function downloadPDF() { window.print(); }
</script>
</body>
</html>
