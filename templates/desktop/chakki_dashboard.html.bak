{% extends "desktop/base.html" %}
{% block title %}Dashboard | {{ tenant.name }}{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">🌾 Dashboard</h2>
    <a href="/portal/{{ tenant.schema_name }}/chakki/add/" class="btn-new-order" style="background:var(--accent);color:#fff;border:none;border-radius:40px;padding:0.4rem 1.4rem;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:0.4rem;box-shadow:0 4px 12px rgba(26,42,58,0.2);">
        <i class="fas fa-plus-circle"></i> New Order
    </a>
</div>

{% if ready_count > 0 %}
<div class="alert alert-warning blink" role="alert" style="border-radius:var(--radius);border-left:4px solid #f5a623;">
    <strong><i class="fas fa-exclamation-triangle"></i> {{ ready_count }} order(s) ready!</strong>
    <a href="/portal/{{ tenant.schema_name }}/chakki/?status=ready" class="alert-link">View now</a>
</div>
{% endif %}

<!-- Hero Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="card p-3 text-center" style="border-left:4px solid var(--accent);">
            <div class="text-muted small text-uppercase">Total Orders</div>
            <div class="h3 fw-bold">{{ pending|add:ready|add:completed }}</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card p-3 text-center" style="border-left:4px solid #6c757d;">
            <div class="text-muted small text-uppercase">Pending</div>
            <div class="h3 fw-bold">{{ pending }}</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card p-3 text-center" style="border-left:4px solid #ffc107;">
            <div class="text-muted small text-uppercase">Ready</div>
            <div class="h3 fw-bold text-warning">{{ ready }}</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card p-3 text-center" style="border-left:4px solid #28a745;">
            <div class="text-muted small text-uppercase">Completed</div>
            <div class="h3 fw-bold text-success">{{ completed }}</div>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small text-uppercase">Total Income</div>
                    <div class="h2 fw-bold text-accent">₹{{ total_income|default:"0" }}</div>
                </div>
                <i class="fas fa-arrow-up fa-2x text-success opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small text-uppercase">Total Expenses</div>
                    <div class="h2 fw-bold text-danger">₹{{ total_expenses|default:"0" }}</div>
                </div>
                <i class="fas fa-arrow-down fa-2x text-danger opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <a href="/portal/{{ tenant.schema_name }}/chakki/add/" class="card text-decoration-none p-3 text-center h-100 shadow-sm">
            <i class="fas fa-plus-circle fa-2x text-accent"></i>
            <h6 class="mt-2">New Order</h6>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a href="/portal/{{ tenant.schema_name }}/chakki/orders/pending/" class="card text-decoration-none p-3 text-center h-100 shadow-sm">
            <i class="fas fa-clock fa-2x text-secondary"></i>
            <h6 class="mt-2">Pending</h6>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a href="/portal/{{ tenant.schema_name }}/chakki/orders/ready/" class="card text-decoration-none p-3 text-center h-100 shadow-sm">
            <i class="fas fa-hourglass-half fa-2x text-warning"></i>
            <h6 class="mt-2">Ready</h6>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a href="/portal/{{ tenant.schema_name }}/expenses/" class="card text-decoration-none p-3 text-center h-100 shadow-sm">
            <i class="fas fa-money-bill-wave fa-2x text-primary"></i>
            <h6 class="mt-2">Expenses</h6>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a href="/portal/{{ tenant.schema_name }}/expenses/add/" class="card text-decoration-none p-3 text-center h-100 shadow-sm">
            <i class="fas fa-plus fa-2x text-success"></i>
            <h6 class="mt-2">Add Expense</h6>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a href="/portal/{{ tenant.schema_name }}/chakki/settings/" class="card text-decoration-none p-3 text-center h-100 shadow-sm">
            <i class="fas fa-cog fa-2x text-secondary"></i>
            <h6 class="mt-2">Settings</h6>
        </a>
    </div>
</div>

<!-- Recent Orders -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold">Recent Orders</h5>
    <a href="/portal/{{ tenant.schema_name }}/chakki/orders/pending/" class="btn btn-sm btn-outline-secondary">See all</a>
</div>
<div class="card p-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#ID</th>
                    <th>Customer</th>
                    <th>Total</th>
                    <th>Paid</th>
                    <th>Status</th>
                    <th>Ready</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for o in recent_orders %}
                <tr>
                    <td>{{ o.id }}</td>
                    <td>{{ o.customer.name }}</td>
                    <td>₹{{ o.total_amount }}</td>
                    <td>₹{{ o.amount_paid }}</td>
                    <td>
                        <span class="badge {% if o.status == 'ready' %}bg-warning{% elif o.status == 'completed' %}bg-success{% elif o.payment_status == 'partial' %}bg-info{% else %}bg-secondary{% endif %}">
                            {% if o.status == 'ready' %}Ready{% elif o.status == 'completed' %}Done{% elif o.payment_status == 'partial' %}Partial{% else %}Pending{% endif %}
                        </span>
                    </td>
                    <td>{{ o.ready_time|date:"d M H:i" }}</td>
                    <td>
                        <a href="/portal/{{ tenant.schema_name }}/chakki/order/{{ o.id }}/" class="btn btn-sm btn-outline-primary">View</a>
                        {% if o.status != 'completed' %}
                            <a href="/portal/{{ tenant.schema_name }}/chakki/complete-action/{{ o.id }}/" class="btn btn-sm btn-success">Complete</a>
                        {% endif %}
                    </td>
                </tr>
                {% empty %}
                <tr><td colspan="7" class="text-center text-muted">No orders yet.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
