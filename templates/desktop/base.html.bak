<!DOCTYPE html>
<html>
<head>
    <title>{% block title %}SaaS System{% endblock %}</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --primary-dark: #1a1a2e;
            --primary-light: #2d2d44;
            --accent: #e67e22;
            --accent-hover: #d35400;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --text: #1a1a2e;
            --text-secondary: #4a4a6a;
            --border: #e2e8f0;
            --shadow: 0 4px 20px rgba(0,0,0,0.05);
            --radius: 12px;
        }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--text);
        }
        /* ---------- Sidebar ---------- */
        .sidebar {
            background: var(--primary-dark);
            min-height: 100vh;
            padding: 1.2rem 0;
            box-shadow: 2px 0 12px rgba(0,0,0,0.08);
            transition: all 0.25s;
        }
        .sidebar .brand {
            color: #fff;
            padding: 0 1.2rem 1.8rem 1.2rem;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            margin-bottom: 0.8rem;
        }
        .sidebar .brand h4 {
            font-weight: 700;
            letter-spacing: -0.02em;
            margin: 0;
        }
        .sidebar .brand small {
            display: block;
            font-weight: 400;
            font-size: 0.7rem;
            color: rgba(255,255,255,0.4);
            margin-top: 2px;
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.7);
            padding: 0.6rem 1.2rem;
            border-radius: 0.5rem;
            margin: 0.15rem 0.8rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            transition: all 0.2s;
            font-weight: 500;
            font-size: 0.9rem;
        }
        .sidebar .nav-link:hover {
            background: rgba(255,255,255,0.06);
            color: #fff;
        }
        .sidebar .nav-link i {
            width: 22px;
            text-align: center;
            font-size: 1rem;
        }
        .sidebar .nav-link .badge {
            margin-left: auto;
            font-weight: 600;
            padding: 0.2rem 0.6rem;
        }
        .sidebar .collapse-menu .nav-link {
            padding-left: 2.5rem;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.55);
        }
        .sidebar .collapse-menu .nav-link:hover {
            color: #fff;
        }
        /* ---------- Header ---------- */
        .header {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0.6rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 8px rgba(0,0,0,0.02);
        }
        .header .search-box {
            width: 320px;
        }
        .header .search-box input {
            border-radius: 30px;
            border: 1px solid var(--border);
            padding: 0.4rem 1rem;
            font-size: 0.9rem;
            background: var(--bg);
        }
        .header .search-box input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(230,126,34,0.12);
        }
        .header .notifications {
            position: relative;
            cursor: pointer;
        }
        .header .notifications .badge {
            position: absolute;
            top: -6px;
            right: -10px;
            background: #ef4444;
            border-radius: 50%;
            font-size: 0.65rem;
            padding: 3px 6px;
            color: #fff;
        }
        .header .notifications .dropdown-menu {
            min-width: 300px;
            max-height: 400px;
            overflow-y: auto;
            border-radius: var(--radius);
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
        }
        /* ---------- Main content ---------- */
        .main-content {
            padding: 1.8rem;
        }
        /* ---------- Misc ---------- */
        .blink {
            animation: blink 1s step-end infinite;
        }
        @keyframes blink {
            50% { opacity: 0; }
        }
        .card {
            border: none;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            box-shadow: 0 8px 30px rgba(0,0,0,0.07);
        }
        .btn-accent {
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 30px;
            padding: 0.4rem 1.2rem;
            font-weight: 600;
            transition: 0.2s;
        }
        .btn-accent:hover {
            background: var(--accent-hover);
            color: #fff;
        }
        .btn-accent:active {
            transform: scale(0.96);
        }
        @media (max-width: 768px) {
            .sidebar { min-height: auto; width: 100%; }
            .header .search-box { width: 100%; }
        }
    
        /* Global New Order Button */
        .global-new-order-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: var(--accent);
            color: #fff !important;
            border: none;
            border-radius: 30px;
            padding: 0.4rem 1.2rem;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            transition: background 0.2s, transform 0.15s;
            margin-left: 0.8rem;
        }
        .global-new-order-btn:hover {
            background: var(--accent-hover);
            color: #fff !important;
        }
        .global-new-order-btn:active {
            transform: scale(0.95);
        }
        .global-new-order-btn i {
            font-size: 0.9rem;
        }
        @media (max-width: 768px) {
            .global-new-order-btn {
                padding: 0.3rem 0.8rem;
                font-size: 0.8rem;
            }
        }
    </style>
    {% block extra_head %}{% endblock %}

    <!-- PWA Meta & Manifest -->
    <link rel="manifest" href="/static/manifest.json">
    <meta name="theme-color" content="#343a40">
    <link rel="apple-touch-icon" href="/static/apple-touch-icon.png">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
</head>
<body>
<div class="container-fluid">
<div class="row">
    <!-- Sidebar -->
    <nav class="col-md-2 d-md-block sidebar">
        <div class="brand">
            <h4>{{ tenant.name|default:"Chakki" }}</h4>
            <small>Flour Mill Management</small>
        </div>
        <div class="collapse d-md-block" id="sidebarCollapse">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" href="/portal/{{ tenant.schema_name }}/dashboard/">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="collapse" href="#chakkiMenu" role="button" aria-expanded="true" onclick="window.location.href='/portal/{{ tenant.schema_name }}/chakki/';">
                        <i class="fas fa-wheat-awn"></i> Chakki
                    </a>
                    <div class="collapse show" id="chakkiMenu">
                        <ul class="nav flex-column collapse-menu">
                            <li class="nav-item"><a class="nav-link" href="/portal/{{ tenant.schema_name }}/chakki/orders/pending/">
                                Pending <span class="badge bg-danger rounded-pill">{{ pending_count }}</span>
                            </a></li>
                            <li class="nav-item"><a class="nav-link" href="/portal/{{ tenant.schema_name }}/chakki/orders/ready/">
                                Ready <span class="badge bg-warning rounded-pill">{{ ready_count }}</span>
                            </a></li>
                            <li class="nav-item"><a class="nav-link" href="/portal/{{ tenant.schema_name }}/chakki/orders/partial/">
                                Partial <span class="badge bg-info rounded-pill">{{ partial_count }}</span>
                            </a></li>
                            <li class="nav-item"><a class="nav-link" href="/portal/{{ tenant.schema_name }}/chakki/orders/completed/">
                                Completed <span class="badge bg-success rounded-pill">{{ completed_count }}</span>
                            </a></li>
                        </ul>
                    </div>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/portal/{{ tenant.schema_name }}/expenses/">
                        <i class="fas fa-money-bill-wave"></i> Expenses
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/portal/{{ tenant.schema_name }}/customers/">
                        <i class="fas fa-users"></i> Customers
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/portal/{{ tenant.schema_name }}/chakki/settings/">
                        <i class="fas fa-cog"></i> Settings
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/portal/{{ tenant.schema_name }}/logout/">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Main -->
    <main class="col-md-10 ms-sm-auto px-md-4">
        <div class="header">
            <div>
                <button class="btn btn-outline-secondary d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarCollapse">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
            <div class="search-box">
                <form action="/portal/{{ tenant.schema_name }}/chakki/search/" method="get" class="d-flex">
                    <input class="form-control me-2" type="search" name="q" placeholder="Search orders, customers..." aria-label="Search">
                    <button class="btn btn-outline-secondary" type="submit"><i class="fas fa-search"></i></button>
                </form>
            </div>
            <div class="notifications dropdown">
                <i class="fas fa-bell fa-lg" data-bs-toggle="dropdown" aria-expanded="false"></i>
                <span class="badge" id="notif-count">{{ ready_count }}</span>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header">Ready Orders</h6></li>
                    {% if ready_orders %}
                        {% for order in ready_orders %}
                            <li><a class="dropdown-item" href="/portal/{{ tenant.schema_name }}/chakki/order/{{ order.id }}/">
                                #{{ order.id }} – {{ order.customer.name }}
                            </a></li>
                        {% endfor %}
                    {% else %}
                        <li><span class="dropdown-item text-muted">No ready orders</span></li>
                    {% endif %}
                </ul>
            </div>
        </div>
        <div class="main-content">
            {% if messages %}
                {% for m in messages %}
                    <div class="alert alert-info alert-dismissible fade show">{{ m|safe }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                {% endfor %}
            {% endif %}
            {% block content %}{% endblock %}
        </div>
    </main>
</div>
</div>


    <script>
    (function() {
        function updateReadyOrders() {
            var tenant = '{{ tenant.schema_name }}';
            var url = '/portal/' + tenant + '/chakki/check-ready/';
            fetch(url)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(data => {
                    // Update badge count
                    var badge = document.querySelector('.notifications .badge, .notif-icon .badge');
                    if (badge) {
                        badge.textContent = data.count;
                        badge.style.display = data.count > 0 ? 'inline' : 'none';
                    }
                    // Update dropdown list
                    var dropdownMenu = document.querySelector('.notifications .dropdown-menu, .notif-dropdown .dropdown-menu');
                    if (dropdownMenu) {
                        // Keep the header (first child)
                        var header = dropdownMenu.querySelector('.dropdown-header');
                        // Remove all items after header
                        while (dropdownMenu.children.length > 1) {
                            dropdownMenu.removeChild(dropdownMenu.lastChild);
                        }
                        // Add new items
                        if (data.orders.length > 0) {
                            data.orders.forEach(order => {
                                var link = document.createElement('a');
                                link.className = 'dropdown-item';
                                link.href = '/portal/' + tenant + '/chakki/order/' + order.id + '/';
                                link.textContent = 'Order #' + order.id + ' - ' + order.customer_name;
                                dropdownMenu.appendChild(link);
                            });
                            // Add "View all" link
                            var viewAll = document.createElement('a');
                            viewAll.className = 'dropdown-item text-center fw-bold';
                            viewAll.href = '/portal/' + tenant + '/chakki/?status=ready';
                            viewAll.textContent = 'View all ready orders →';
                            dropdownMenu.appendChild(viewAll);
                        } else {
                            var empty = document.createElement('span');
                            empty.className = 'dropdown-item text-muted';
                            empty.textContent = 'No ready orders';
                            dropdownMenu.appendChild(empty);
                        }
                    }
                })
                .catch(error => {
                    console.error('Error fetching ready orders:', error);
                    // Retry after 10 seconds on error
                    setTimeout(updateReadyOrders, 10000);
                });
        }
        // Initial call and then every 15 seconds
        updateReadyOrders();
        setInterval(updateReadyOrders, 15000);
    })();
    </script>
    

</body>
</html>
