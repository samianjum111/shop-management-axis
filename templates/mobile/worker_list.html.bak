{% extends "mobile/base.html" %}
{% block title %}Workers | {{ tenant.name }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-2">
    <a href="/portal/{{ tenant.schema_name }}/expenses/workers/attendance/" class="btn btn-outline-secondary btn-sm">📋 Attendance</a>
    <h5 class="fw-bold">Workers</h5>
    <div>
        <a href="/portal/{{ tenant.schema_name }}/expenses/workers/category/add/" class="btn btn-outline-secondary btn-sm">+ Category</a>
        <a href="/portal/{{ tenant.schema_name }}/expenses/workers/add/" class="btn btn-primary-custom btn-sm">+ Worker</a>
    </div>
</div>
{% for w in workers %}
<div class="expense-item">
    <div class="top">
        <span>{{ w.name }}</span>
        <span>₹{{ w.salary_amount }}/{{ w.salary_type }}</span>
    </div>
    <div class="meta">
        <span>{{ w.category.name|default:"No Category" }}</span>
        <span>{{ w.status|title }}</span>
        <span>Joining: {{ w.joining_date|date:"d M Y" }}</span>
    </div>
    <a href="/portal/{{ tenant.schema_name }}/expenses/workers/{{ w.id }}/" class="action-link me-2">Profile</a>
    <a href="/portal/{{ tenant.schema_name }}/expenses/workers/edit/{{ w.id }}/" class="action-link">Edit</a>
</div>
{% empty %}
<div class="empty-state">No workers</div>
{% endfor %}
    <!-- Category Management -->
    <div class="mt-4">
        <h6 class="fw-bold">Categories</h6>
        <form method="post" action="/portal/{{ tenant.schema_name }}/expenses/workers/category/add/" class="d-flex gap-2 mb-2">
            {% csrf_token %}
            <input type="text" name="name" class="form-control form-control-sm" placeholder="New category" required>
            <button type="submit" class="btn btn-primary-custom btn-sm">Add</button>
        </form>
        <div class="category-list">
            {% for cat in categories %}
            <div class="d-flex justify-content-between align-items-center border-bottom py-1">
                <span>{{ cat.name }}</span>
                <div>
                    <button class="btn btn-sm btn-outline-secondary me-1" onclick="editCategory({{ cat.id }}, '{{ cat.name }}', '{{ cat.description|default:'' }}')">Edit</button>
                    <form method="post" action="/portal/{{ tenant.schema_name }}/expenses/workers/category/delete/{{ cat.id }}/" style="display:inline;">
                        {% csrf_token %}
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this category?')">Delete</button>
                    </form>
                </div>
            </div>
            {% empty %}
            <div class="text-muted">No categories yet.</div>
            {% endfor %}
        </div>
    </div>

    <!-- Edit Category Modal -->
    <div class="modal fade" id="editCategoryModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <form method="post" action="/portal/{{ tenant.schema_name }}/expenses/workers/category/edit/">
            {% csrf_token %}
            <div class="modal-header">
              <h5 class="modal-title">Edit Category</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <input type="hidden" name="category_id" id="edit_category_id">
              <div class="mb-2">
                <label>Name</label>
                <input type="text" name="name" id="edit_category_name" class="form-control" required>
              </div>
              <div class="mb-2">
                <label>Description</label>
                <textarea name="description" id="edit_category_description" class="form-control"></textarea>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-primary">Save</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script>
    function editCategory(id, name, description) {
        document.getElementById('edit_category_id').value = id;
        document.getElementById('edit_category_name').value = name;
        document.getElementById('edit_category_description').value = description || '';
        var modal = new bootstrap.Modal(document.getElementById('editCategoryModal'));
        modal.show();
    }
    </script>

{% endblock %}
