{% extends "mobile/base.html" %}
{% block title %}More | {{ tenant.name }}{% endblock %}

{% block extra_head %}
<style>
  /* ===== Premium Upgrades – uses your theme variables ===== */
  .premium-header {
    padding: 0.5rem 0 0.2rem;
    background: var(--surface);
    border-radius: var(--radius) var(--radius) 0 0;
    margin: -0.5rem -0.5rem 0.5rem -0.5rem;
    padding: 1.2rem 1rem 0.5rem;
    border-bottom: 2px solid var(--accent-light);
  }

  .section-title {
    font-weight: 700;
    font-size: 1rem;
    margin: 1.6rem 0 0.6rem;
    color: var(--text-secondary);
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.2rem;
  }
  .section-title .icon {
    font-size: 1.2rem;
    color: var(--accent);
  }
  .section-title::after {
    content: '';
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-light), transparent);
    margin-left: 0.5rem;
  }

  .more-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
    margin-top: 0.2rem;
  }

  .more-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem 0.5rem;
    text-align: center;
    text-decoration: none;
    color: var(--text);
    box-shadow: var(--shadow);
    transition: all 0.25s cubic-bezier(0.2, 0, 0, 1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  .more-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .more-card:active {
    transform: scale(0.95);
  }
  .more-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .more-card:hover::before {
    opacity: 1;
  }
  .more-card .icon {
    font-size: 2.2rem;
    color: var(--accent);
    line-height: 1.2;
    transition: transform 0.2s;
  }
  .more-card:hover .icon {
    transform: scale(1.08);
  }
  .more-card .label {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .more-card .desc {
    font-size: 0.65rem;
    color: var(--muted);
    opacity: 0.7;
    font-weight: 500;
  }

  /* ----- "Coming Soon" badge ----- */
  .badge-soon {
    background: var(--accent-light);
    color: var(--accent);
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.1rem 0.5rem;
    border-radius: 30px;
    letter-spacing: 0.04em;
    border: 1px solid rgba(26,42,58,0.15);
    margin-top: 0.1rem;
  }
  .more-card.disabled-card {
    opacity: 0.85;
    cursor: default;
  }
  .more-card.disabled-card:active {
    transform: none;
  }
  .more-card.disabled-card:hover {
    transform: none;
    border-color: var(--border);
    box-shadow: var(--shadow);
  }
  .more-card.disabled-card:hover::before {
    opacity: 0;
  }
  .more-card.disabled-card .icon {
    color: var(--muted);
  }

  /* ----- Coming Soon Modal ----- */
  .modal-coming-soon .modal-content {
    border-radius: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    text-align: center;
    padding: 1.5rem 1.2rem;
  }
  .modal-coming-soon .modal-icon {
    font-size: 3.5rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
    display: block;
  }
  .modal-coming-soon .modal-title {
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--text);
    margin-bottom: 0.3rem;
  }
  .modal-coming-soon .modal-message {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 1.2rem;
    line-height: 1.4;
  }
  .modal-coming-soon .btn-close-premium {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 40px;
    padding: 0.5rem 2rem;
    font-weight: 600;
    font-size: 0.9rem;
    transition: 0.2s;
    cursor: pointer;
  }
  .modal-coming-soon .btn-close-premium:active {
    transform: scale(0.94);
  }

  /* Modal backdrop and positioning */
  .modal-coming-soon {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    z-index: 1050;
    justify-content: center;
    align-items: center;
    padding: 1.5rem;
    backdrop-filter: blur(4px);
  }
  .modal-coming-soon.show {
    display: flex;
  }

  @media (max-width: 480px) {
    .more-grid {
      gap: 0.7rem;
    }
    .more-card {
      padding: 1rem 0.3rem;
    }
    .more-card .icon {
      font-size: 1.8rem;
    }
    .more-card .label {
      font-size: 0.75rem;
    }
    .modal-coming-soon .modal-icon {
      font-size: 2.8rem;
    }
  }
</style>
{% endblock %}

{% block body %}
<!-- Header -->
<div class="premium-header">
  <h5 class="fw-bold mb-1">More</h5>
</div>

<!-- Customers -->
<div class="section-title">
  <span class="icon"><i class="fas fa-users"></i></span> Customers
</div>
<div class="more-grid">
  <a href="/portal/{{ tenant.schema_name }}/chakki/customer/create/" class="more-card">
    <div class="icon"><i class="fas fa-user-plus"></i></div>
    <span class="label">Create Customer</span>
    <span class="desc">Add a new regular customer</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/customers/" class="more-card">
    <div class="icon"><i class="fas fa-address-book"></i></div>
    <span class="label">View Customers</span>
    <span class="desc">Manage all customers</span>
  </a>
</div>

<!-- Orders -->
<div class="section-title">
  <span class="icon"><i class="fas fa-wheat-awn"></i></span> Orders
</div>
<div class="more-grid">
  <a href="/portal/{{ tenant.schema_name }}/chakki/add/" class="more-card">
    <div class="icon"><i class="fas fa-plus-circle"></i></div>
    <span class="label">New Order</span>
    <span class="desc">Create a new order</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/chakki/orders/pending/" class="more-card">
    <div class="icon"><i class="fas fa-clock"></i></div>
    <span class="label">Pending</span>
    <span class="desc">{{ pending_count }} pending</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/chakki/orders/ready/" class="more-card">
    <div class="icon"><i class="fas fa-hourglass-half"></i></div>
    <span class="label">Ready</span>
    <span class="desc">{{ ready_count }} ready</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/chakki/orders/completed/" class="more-card">
    <div class="icon"><i class="fas fa-check-circle"></i></div>
    <span class="label">Completed</span>
    <span class="desc">{{ completed_count }} done</span>
  </a>
</div>

<!-- Finance & Expenses -->
<div class="section-title">
  <span class="icon"><i class="fas fa-coins"></i></span> Finance &amp; Expenses
</div>
<div class="more-grid">
  <a href="/portal/{{ tenant.schema_name }}/expenses/" class="more-card">
    <div class="icon"><i class="fas fa-chart-pie"></i></div>
    <span class="label">Dashboard</span>
    <span class="desc">Overview</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/expenses/daily/" class="more-card">
    <div class="icon"><i class="fas fa-receipt"></i></div>
    <span class="label">Daily Expenses</span>
    <span class="desc">Add &amp; view daily</span>
  </a>

  <!-- ===== COMING SOON: Loans Given ===== -->
  <div class="more-card disabled-card" onclick="showComingSoon()">
    <div class="icon"><i class="fas fa-hand-holding-usd"></i></div>
    <span class="label">Loans Given</span>
    <span class="desc">Udhaar</span>
    <span class="badge-soon">Soon</span>
  </div>

  <!-- ===== COMING SOON: Loans Taken ===== -->
  <div class="more-card disabled-card" onclick="showComingSoon()">
    <div class="icon"><i class="fas fa-hand-holding-heart"></i></div>
    <span class="label">Loans Taken</span>
    <span class="desc">Borrowed</span>
    <span class="badge-soon">Soon</span>
  </div>

  <!-- ===== COMING SOON: Reminders ===== -->
  <div class="more-card disabled-card" onclick="showComingSoon()">
    <div class="icon"><i class="fas fa-bell"></i></div>
    <span class="label">Reminders</span>
    <span class="desc">Pending</span>
    <span class="badge-soon">Soon</span>
  </div>

  <a href="/portal/{{ tenant.schema_name }}/expenses/workers/" class="more-card">
    <div class="icon"><i class="fas fa-users"></i></div>
    <span class="label">Workers</span>
    <span class="desc">Manage staff</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/expenses/workers/attendance/" class="more-card">
    <div class="icon"><i class="fas fa-clipboard-list"></i></div>
    <span class="label">Attendance</span>
    <span class="desc">Daily attendance</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/expenses/workers/payments/" class="more-card">
    <div class="icon"><i class="fas fa-credit-card"></i></div>
    <span class="label">Pending Payments</span>
    <span class="desc">Due salaries</span>
  </a>
</div>

<!-- Reports -->
<div class="section-title">
  <span class="icon"><i class="fas fa-chart-pie"></i></span> Reports
</div>
<div class="more-grid">
  <a href="/portal/{{ tenant.schema_name }}/reports/" class="more-card">
    <div class="icon"><i class="fas fa-chart-pie"></i></div>
    <span class="label">Dashboard</span>
    <span class="desc">Overview</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/reports/revenue/" class="more-card">
    <div class="icon"><i class="fas fa-coins"></i></div>
    <span class="label">Revenue</span>
    <span class="desc">Income details</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/reports/categories/" class="more-card">
    <div class="icon"><i class="fas fa-tags"></i></div>
    <span class="label">Categories</span>
    <span class="desc">Performance</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/reports/customers/" class="more-card">
    <div class="icon"><i class="fas fa-users"></i></div>
    <span class="label">Customers</span>
    <span class="desc">Top spenders</span>
  </a>
  <a href="/portal/{{ tenant.schema_name }}/reports/orders/" class="more-card">
    <div class="icon"><i class="fas fa-clipboard-list"></i></div>
    <span class="label">Orders</span>
    <span class="desc">Status report</span>
  </a>
</div>

<!-- Settings -->
<div class="section-title">
  <span class="icon"><i class="fas fa-cog"></i></span> Settings
</div>
<div class="more-grid">
  <a href="/portal/{{ tenant.schema_name }}/chakki/settings/" class="more-card">
    <div class="icon"><i class="fas fa-sliders-h"></i></div>
    <span class="label">Settings</span>
    <span class="desc">Rates &amp; categories</span>
  </a>
</div>

<!-- ===== COMING SOON MODAL ===== -->
<div class="modal-coming-soon" id="comingSoonModal">
  <div class="modal-content">
    <span class="modal-icon"><i class="fas fa-rocket"></i></span>
    <div class="modal-title">Coming Soon!</div>
    <div class="modal-message">
      This feature is under development.<br>
      We're working hard to bring it to you. Stay tuned!
    </div>
    <button class="btn-close-premium" onclick="closeComingSoon()">Got it</button>
  </div>
</div>

<script>
  function showComingSoon() {
    document.getElementById('comingSoonModal').classList.add('show');
  }

  function closeComingSoon() {
    document.getElementById('comingSoonModal').classList.remove('show');
  }

  // Close modal when clicking outside the content
  document.getElementById('comingSoonModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeComingSoon();
    }
  });
</script>
{% endblock %}
