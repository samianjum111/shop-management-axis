{% extends "mobile/base.html" %}
{% load static %}
{% block title %}{{ category.name }} Analytics | {{ tenant.name }}{% endblock %}

{% block extra_head %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
  /* ===== PREMIUM MOBILE CATEGORY DETAIL – FULL DEPTH ===== */
  :root {
    --hero-grad: linear-gradient(145deg, #0f1a2e, #1a2d4a);
    --accent-grad: linear-gradient(135deg, #f59e0b, #d97706);
    --card-radius: 18px;
    --card-shadow: 0 6px 20px rgba(0,0,0,0.06);
    --tap-scale: 0.96;
    --transition: all 0.2s ease;
  }

  /* ----- HERO ----- */
  .hero-section {
    background: var(--hero-grad);
    border-radius: var(--card-radius);
    padding: 1.4rem 1.2rem 1rem;
    color: #fff;
    margin-bottom: 1.2rem;
    position: relative;
    overflow: hidden;
  }
  .hero-section::after {
    content: '';
    position: absolute;
    top: -30%;
    right: -20%;
    width: 220px;
    height: 220px;
    background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .hero-section .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    z-index: 1;
  }
  .hero-section .hero-title {
    font-size: 1.4rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .hero-section .hero-title svg {
    width: 1.8rem;
    height: 1.8rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
  }
  .hero-section .hero-type {
    background: rgba(255,255,255,0.15);
    padding: 0.2rem 0.9rem;
    border-radius: 30px;
    font-size: 0.7rem;
    font-weight: 600;
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.06);
  }
  .hero-section .hero-sub {
    font-size: 0.8rem;
    opacity: 0.7;
    margin-top: 0.1rem;
    position: relative;
    z-index: 1;
  }
  .hero-section .hero-revenue {
    font-size: 1.2rem;
    font-weight: 700;
    margin-top: 0.4rem;
    position: relative;
    z-index: 1;
  }
  .hero-section .hero-actions {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.8rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }
  .hero-section .hero-actions .btn {
    padding: 0.25rem 1rem;
    border-radius: 30px;
    font-weight: 600;
    font-size: 0.8rem;
    border: none;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .hero-section .hero-actions .btn-back {
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(4px);
  }
  .hero-section .hero-actions .btn-back:active {
    transform: scale(var(--tap-scale));
  }
  .hero-section .hero-actions .btn-edit {
    background: var(--accent-grad);
    color: #fff;
    box-shadow: 0 2px 8px rgba(245,158,11,0.25);
  }
  .hero-section .hero-actions .btn-edit:active {
    transform: scale(var(--tap-scale));
  }

  /* ----- KPI STRIP (horizontal scroll) ----- */
  .kpi-strip {
    display: flex;
    gap: 0.6rem;
    overflow-x: auto;
    padding: 0.2rem 0 0.8rem;
    margin-bottom: 1rem;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
  }
  .kpi-card {
    flex: 0 0 110px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--card-radius);
    padding: 0.7rem 0.3rem;
    text-align: center;
    box-shadow: var(--card-shadow);
    scroll-snap-align: start;
    transition: var(--transition);
  }
  .kpi-card:active {
    transform: scale(var(--tap-scale));
  }
  .kpi-card .number {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
  }
  .kpi-card .label {
    font-size: 0.55rem;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .kpi-card .icon {
    display: block;
    margin: 0 auto 0.1rem;
    width: 1.2rem;
    height: 1.2rem;
    stroke: var(--accent);
    fill: none;
  }
  .kpi-card .icon.profit {
    stroke: #22c55e;
  }
  .kpi-card .icon.cost {
    stroke: #ef4444;
  }

  /* ----- CHART CAROUSEL ----- */
  .carousel-premium {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--card-radius);
    padding: 0.6rem 0.6rem 0.8rem;
    margin-bottom: 1.2rem;
    box-shadow: var(--card-shadow);
  }
  .carousel-premium .carousel-title {
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0.2rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .carousel-premium .carousel-title svg {
    width: 1.2rem;
    height: 1.2rem;
    stroke: var(--accent);
    fill: none;
  }
  .carousel-premium .carousel-inner {
    border-radius: 12px;
    overflow: hidden;
  }
  .carousel-premium .carousel-item canvas {
    width: 100% !important;
    height: auto !important;
    max-height: 190px;
  }
  .carousel-premium .carousel-control-prev,
  .carousel-premium .carousel-control-next {
    width: 8%;
    opacity: 0.7;
  }
  .carousel-premium .carousel-control-prev-icon,
  .carousel-premium .carousel-control-next-icon {
    background-color: rgba(0,0,0,0.2);
    border-radius: 50%;
    padding: 0.2rem;
  }
  .carousel-premium .carousel-indicators {
    position: relative;
    bottom: -0.2rem;
    margin-top: 0.3rem;
  }
  .carousel-premium .carousel-indicators button {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--muted);
    border: none;
    margin: 0 5px;
    transition: all 0.3s;
  }
  .carousel-premium .carousel-indicators button.active {
    background-color: var(--accent);
    transform: scale(1.3);
  }

  /* ----- ORDER CARDS ----- */
  .order-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--card-radius);
    padding: 0.8rem 1rem;
    margin-bottom: 0.7rem;
    box-shadow: var(--card-shadow);
    transition: var(--transition);
    position: relative;
    overflow: hidden;
  }
  .order-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--accent-grad);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .order-card:active {
    transform: scale(0.98);
  }
  .order-card:active::after {
    opacity: 1;
  }
  .order-card .top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.2rem;
  }
  .order-card .order-id {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--accent);
  }
  .order-card .amount {
    font-weight: 700;
    font-size: 1rem;
    color: var(--text);
  }
  .order-card .customer {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text);
  }
  .order-card .meta {
    font-size: 0.7rem;
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.6rem;
    margin-top: 0.1rem;
  }
  .order-card .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.2rem;
  }
  .badge-premium {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    border-radius: 30px;
    font-weight: 600;
    font-size: 0.65rem;
    text-transform: capitalize;
  }
  .badge-ready { background: #fef3e2; color: #d35400; }
  .badge-completed { background: #d4edda; color: #155724; }
  .badge-pending { background: #e2e3e5; color: #383d41; }
  .badge-cancelled { background: #f8d7da; color: #b02a37; }
  .badge-paid { background: #d4edda; color: #155724; }
  .badge-partial { background: #d1ecf1; color: #0c5460; }
  .badge-unpaid { background: #f8d7da; color: #b02a37; }
  .order-card .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.4rem;
  }
  .order-card .actions .btn-sm {
    padding: 0.2rem 0.8rem;
    border-radius: 2rem;
    font-size: 0.7rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }
  .btn-outline-primary {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
  }
  .btn-outline-primary:active {
    transform: scale(var(--tap-scale));
  }
  .btn-outline-secondary {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }
  .btn-outline-secondary:active {
    transform: scale(var(--tap-scale));
  }

  /* ----- EMPTY STATE ----- */
  .empty-state {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--muted);
    background: var(--surface);
    border-radius: var(--card-radius);
    border: 1px solid var(--border);
  }
  .empty-state svg {
    width: 2.8rem;
    height: 2.8rem;
    stroke: var(--border);
    fill: none;
    stroke-width: 1.5;
    display: block;
    margin: 0 auto 0.3rem;
  }
  .empty-state p {
    font-size: 0.9rem;
    margin: 0;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 400px) {
    .kpi-card { flex: 0 0 90px; }
    .kpi-card .number { font-size: 1.2rem; }
    .carousel-premium .carousel-item canvas { max-height: 150px; }
  }
  @media (max-width: 360px) {
    .kpi-card { flex: 0 0 80px; }
    .kpi-card .number { font-size: 1rem; }
  }

  /* ----- MODAL STYLING (same as settings) ----- */
  .modal-content {
    border-radius: var(--card-radius) var(--card-radius) 0 0;
    border: none;
    background: var(--surface);
    box-shadow: 0 -10px 40px rgba(0,0,0,0.1);
    animation: slideUp 0.3s ease;
  }
  @keyframes slideUp {
    0% { transform: translateY(30px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }
  .modal-header {
    border-bottom: 1px solid var(--border);
    padding: 1rem 1.2rem;
  }
  .modal-header .modal-title {
    font-weight: 700;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .modal-header .modal-title i {
    color: var(--accent);
  }
  .modal-body {
    padding: 1.2rem;
  }
  .modal-footer {
    border-top: 1px solid var(--border);
    padding: 1rem 1.2rem;
  }
  .modal .form-group {
    margin-bottom: 1rem;
  }
  .modal .form-group label {
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--text-secondary);
    display: block;
    margin-bottom: 0.2rem;
  }
  .modal .form-group input,
  .modal .form-group select,
  .modal .form-group textarea {
    width: 100%;
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg);
    color: var(--text);
    font-size: 0.9rem;
    transition: var(--transition);
    outline: none;
  }
  .modal .form-group input:focus,
  .modal .form-group select:focus,
  .modal .form-group textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(245,158,11,0.1);
  }
  .modal .btn-primary {
    background: var(--accent-grad);
    border: none;
    border-radius: 30px;
    padding: 0.4rem 1.4rem;
    font-weight: 600;
  }
  .modal .btn-secondary {
    background: var(--surface-alt);
    border: none;
    border-radius: 30px;
    padding: 0.4rem 1.4rem;
    font-weight: 600;
    color: var(--text-secondary);
  }
</style>
{% endblock %}

{% block body %}

<!-- ===== HERO ===== -->
<div class="hero-section">
  <div class="hero-top">
    <div>
      <div class="hero-title">
        <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/><path d="M9 7l6 5-6 5V7z"/></svg>
        {{ category.name }}
      </div>
      <div class="hero-sub">{{ tenant.name }} · {{ type|title }} category</div>
    </div>
    <div>
      <span class="hero-type">{{ type|title }}</span>
    </div>
  </div>
  <div class="hero-revenue">Total Revenue: ₹{{ total_revenue|floatformat:2 }}</div>
  <div class="hero-actions">
    <a href="{% url 'chakki_settings' schema_name=tenant.schema_name %}" class="btn btn-back">
      <svg viewBox="0 0 24 24" width="16" height="16"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
      Back
    </a>
    {% if type == 'grinding' %}
      <button class="btn btn-edit" data-bs-toggle="modal" data-bs-target="#editGrindingModal">
        <svg viewBox="0 0 24 24" width="16" height="16"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit
      </button>
    {% else %}
      <button class="btn btn-edit" data-bs-toggle="modal" data-bs-target="#editSellingModal">
        <svg viewBox="0 0 24 24" width="16" height="16"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit
      </button>
    {% endif %}
  </div>
</div>

<!-- ===== KPI STRIP ===== -->
<div class="kpi-strip">
  {% if type == 'selling' %}
    <div class="kpi-card">
      <svg class="icon" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <div class="number">{{ total_qty|floatformat:2 }}</div>
      <div class="label">Sold</div>
    </div>
    <div class="kpi-card">
      <svg class="icon" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
      <div class="number">{{ total_stock|floatformat:2 }}</div>
      <div class="label">Remaining</div>
    </div>
{% else %}
    <div class="kpi-card">
      <svg class="icon" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
      <div class="number">{{ total_kg|floatformat:2 }}</div>
      <div class="label">KG</div>
    </div>
{% endif %}
  <div class="kpi-card">
    <svg class="icon" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
    <div class="number">₹{{ total_revenue|floatformat:0 }}</div>
    <div class="label">Revenue</div>
  </div>
  {% if total_cost is not None %}
  <div class="kpi-card">
    <svg class="icon cost" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
    <div class="number">₹{{ total_cost|floatformat:0 }}</div>
    <div class="label">Cost</div>
  </div>
  {% endif %}
  {% if total_profit is not None %}
  <div class="kpi-card">
    <svg class="icon profit" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    <div class="number">₹{{ total_profit|floatformat:0 }}</div>
    <div class="label">Profit</div>
  </div>
  {% endif %}
</div>

<!-- ===== CHART CAROUSEL ===== -->
{% if order_data %}
<div class="carousel-premium">
  <div class="carousel-title">
    <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/><path d="M9 7l6 5-6 5V7z"/></svg>
    Charts
  </div>
  <div id="chartCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000" data-bs-touch="true">
    <div class="carousel-indicators">
      <button type="button" data-bs-target="#chartCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Revenue Trend"></button>
      {% if total_profit is not None %}
      <button type="button" data-bs-target="#chartCarousel" data-bs-slide-to="1" aria-label="Profit Trend"></button>
      <button type="button" data-bs-target="#chartCarousel" data-bs-slide-to="2" aria-label="Revenue vs Cost"></button>
      {% else %}
      <button type="button" data-bs-target="#chartCarousel" data-bs-slide-to="1" aria-label="Revenue per Order"></button>
      {% endif %}
    </div>
    <div class="carousel-inner">
      <div class="carousel-item active"><canvas id="revenueChart" height="180"></canvas></div>
      {% if total_profit is not None %}
      <div class="carousel-item"><canvas id="profitChart" height="180"></canvas></div>
      <div class="carousel-item"><canvas id="costRevenueChart" height="180"></canvas></div>
      {% else %}
      <div class="carousel-item"><canvas id="revenuePerOrderChart" height="180"></canvas></div>
      {% endif %}
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#chartCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#chartCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Next</span>
    </button>
  </div>
</div>
{% endif %}

<!-- ===== ORDERS ===== -->
<h5 class="fw-bold mb-2">Orders</h5>
{% for entry in order_data %}
<div class="order-card">
  <div class="top">
    <span class="order-id">#{{ entry.order.id }}</span>
    <span class="amount">₹{{ entry.total|floatformat:2 }}</span>
  </div>
  <div class="customer">{{ entry.order.customer.name }}</div>
  <div class="meta">
    <span>🕒 {{ entry.order.created_at|date:"d M H:i" }}</span>
    {% if entry.profit is not None %}
    <span>Profit: <strong class="{% if entry.profit >= 0 %}text-success{% else %}text-danger{% endif %}">₹{{ entry.profit|floatformat:2 }}</strong></span>
    {% endif %}
  </div>
  <div class="badges">
    <span class="badge-premium
      {% if entry.order.status == 'ready' %}badge-ready
      {% elif entry.order.status == 'completed' %}badge-completed
      {% elif entry.order.status == 'cancelled' %}badge-cancelled
      {% else %}badge-pending{% endif %}">
      {{ entry.order.status|title }}
    </span>
    <span class="badge-premium
      {% if entry.order.payment_status == 'paid' %}badge-paid
      {% elif entry.order.payment_status == 'partial' %}badge-partial
      {% else %}badge-unpaid{% endif %}">
      {{ entry.order.payment_status|title }}
    </span>
  </div>
  <div class="actions">
    <a href="{% url 'order_detail' schema_name=tenant.schema_name order_id=entry.order.id %}" class="btn-sm btn-outline-primary">View</a>
    <button class="btn-sm btn-outline-secondary view-transcript" data-order-id="{{ entry.order.id }}">📄 Transcript</button>
  </div>
</div>
{% empty %}
<div class="empty-state">
  <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
  <p>No orders for this category.</p>
</div>
{% endfor %}

<!-- ===== TRANSCRIPT MODAL ===== -->
<div class="modal fade" id="transcriptModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Order Transcript</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="transcriptModalBody">
        <div class="text-center py-4">Loading...</div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary" id="printTranscriptBtn">Print</button>
      </div>
    </div>
  </div>
</div>

<!-- ===== EDIT MODALS ===== -->

<!-- Edit Grinding Modal -->
{% if type == 'grinding' %}
<div class="modal fade" id="editGrindingModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form method="post" action="{% url 'chakki_settings' schema_name=tenant.schema_name %}">
        {% csrf_token %}
        <input type="hidden" name="action" value="edit_category">
        <input type="hidden" name="category_id" value="{{ category.id }}">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-edit"></i> Edit Grinding Category</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="form-group">
            <label>Name</label>
            <input type="text" name="category_name" class="form-control" value="{{ category.name }}" required>
          </div>
          <div class="form-group">
            <label>Description</label>
            <input type="text" name="category_description" class="form-control" value="{{ category.description }}">
          </div>
          <div class="form-group">
            <label>Grinding Rate (per KG)</label>
            <input type="number" name="grinding_rate" step="0.01" class="form-control" value="{{ category.grinding_rate }}" required>
          </div>
          <div class="form-group">
            <label>Cleaning Rate (per KG) – optional</label>
            <input type="number" name="cleaning_rate" step="0.01" class="form-control" value="{{ category.cleaning_rate|default:'' }}" placeholder="Leave blank for none">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>
{% endif %}

<!-- Edit Selling Modal -->
{% if type == 'selling' %}

<!-- ===== EDIT SELLING MODAL (FULL) ===== -->
<div class="modal fade" id="editSellingModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form method="post" action="{% url 'chakki_settings' schema_name=tenant.schema_name %}">
        {% csrf_token %}
        <input type="hidden" name="action" value="edit_selling_category_with_price">
        <input type="hidden" name="category_id" value="{{ category.id }}">
        <input type="hidden" name="price_id" value="{% if prices %}{{ prices.0.id }}{% endif %}">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-edit"></i> Edit Selling Item</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="form-group">
            <label>Category Name *</label>
            <input type="text" name="category_name" class="form-control" value="{{ category.name }}" required>
          </div>
          <div class="form-group">
            <label>Description</label>
            <input type="text" name="category_description" class="form-control" value="{{ category.description }}">
          </div>
          {% if prices %}
            <div class="form-group">
              <label>Measurement *</label>
              <select name="measurement" class="form-select" required>
                <option value="kg" {% if prices.0.measurement == 'kg' %}selected{% endif %}>KG</option>
                <option value="liter" {% if prices.0.measurement == 'liter' %}selected{% endif %}>Liter</option>
                <option value="gram" {% if prices.0.measurement == 'gram' %}selected{% endif %}>Gram</option>
                <option value="packet" {% if prices.0.measurement == 'packet' %}selected{% endif %}>Packet</option>
                <option value="dozen" {% if prices.0.measurement == 'dozen' %}selected{% endif %}>Dozen</option>
                <option value="piece" {% if prices.0.measurement == 'piece' %}selected{% endif %}>Piece</option>
                <option value="bottle" {% if prices.0.measurement == 'bottle' %}selected{% endif %}>Bottle</option>
              </select>
            </div>
            <div class="form-group">
              <label>Price (per unit) *</label>
              <input type="number" name="price" step="0.01" class="form-control" value="{{ prices.0.price }}" required>
            </div>
            <div class="form-group">
              <label>Stock Quantity</label>
              <input type="number" name="stock" step="0.01" class="form-control" value="{{ prices.0.stock|default:0 }}" required>
            </div>
            <div class="form-group">
              <label>Purchase Price (cost per unit) *</label>
              <input type="number" name="purchase_price" step="0.01" class="form-control" value="{{ prices.0.purchase_price|default:0 }}" required>
            </div>
          {% else %}
            <div class="alert alert-warning">No price defined. Please add a price first.</div>
          {% endif %}
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  // ----- CHART: Revenue Trend (daily) -----
  {% if order_data %}
    const orderData = [
      {% for entry in order_data %}
        { date: "{{ entry.order.created_at|date:'Y-m-d' }}", total: {{ entry.total|floatformat:2 }} },
      {% endfor %}
    ];
    const grouped = {};
    orderData.forEach(item => {
      if (!grouped[item.date]) grouped[item.date] = 0;
      grouped[item.date] += item.total;
    });
    const sortedDates = Object.keys(grouped).sort();
    const labels = sortedDates.map(d => {
      const parts = d.split('-');
      return parts[2] + '/' + parts[1];
    });
    const revenueData = sortedDates.map(d => grouped[d]);

    // 1. Revenue Chart
    if (revenueData.length) {
      new Chart(document.getElementById('revenueChart'), {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Revenue (₹)',
            data: revenueData,
            backgroundColor: 'rgba(245,158,11,0.7)',
            borderColor: '#f59e0b',
            borderWidth: 2,
            borderRadius: 4,
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } },
            x: { grid: { display: false } }
          }
        }
      });
    }

    // 2. Profit Chart (if profit data exists)
    {% if total_profit is not None %}
      const profitData = [
        {% for entry in order_data %}
          {{ entry.profit|floatformat:2 }},
        {% endfor %}
      ];
      // use the same labels (dates)
      if (profitData.length) {
        new Chart(document.getElementById('profitChart'), {
          type: 'bar',
          data: {
            labels: labels,
            datasets: [{
              label: 'Profit (₹)',
              data: profitData,
              backgroundColor: 'rgba(34,197,94,0.7)',
              borderColor: '#22c55e',
              borderWidth: 2,
              borderRadius: 4,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } },
              x: { grid: { display: false } }
            }
          }
        });
      }

      // 3. Revenue vs Cost (if cost available)
      const costData = [
        {% for entry in order_data %}
          {{ entry.cost|floatformat:2 }},
        {% endfor %}
      ];
      if (costData.length) {
        new Chart(document.getElementById('costRevenueChart'), {
          type: 'bar',
          data: {
            labels: labels,
            datasets: [
              {
                label: 'Revenue',
                data: revenueData,
                backgroundColor: 'rgba(245,158,11,0.7)',
                borderColor: '#f59e0b',
                borderWidth: 2,
                borderRadius: 4,
              },
              {
                label: 'Cost',
                data: costData,
                backgroundColor: 'rgba(239,68,68,0.7)',
                borderColor: '#ef4444',
                borderWidth: 2,
                borderRadius: 4,
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom', labels: { color: '#6b7280', font: { size: 10 } } } },
            scales: {
              y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } },
              x: { grid: { display: false } }
            }
          }
        });
      }
    {% else %}
      // If no profit (grinding), show revenue per order (line)
      if (revenueData.length) {
        new Chart(document.getElementById('revenuePerOrderChart'), {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Revenue per Order',
              data: revenueData,
              borderColor: '#f59e0b',
              backgroundColor: 'rgba(245,158,11,0.1)',
              tension: 0.2,
              fill: true,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } },
              x: { grid: { display: false } }
            }
          }
        });
      }
    {% endif %}
  {% endif %}

  // ----- TRANSCRIPT MODAL -----
  const modal = document.getElementById('transcriptModal');
  const modalBody = document.getElementById('transcriptModalBody');
  const printBtn = document.getElementById('printTranscriptBtn');

  document.querySelectorAll('.view-transcript').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const orderId = this.dataset.orderId;
      if (!orderId) return;
      modalBody.innerHTML = '<div class="text-center py-4">Loading...</div>';
      fetch(`/portal/{{ tenant.schema_name }}/chakki/transcript-modal/${orderId}/`)
        .then(response => response.text())
        .then(html => {
          modalBody.innerHTML = html;
          var bsModal = new bootstrap.Modal(modal);
          bsModal.show();
        })
        .catch(() => {
          modalBody.innerHTML = '<div class="alert alert-danger">Error loading transcript.</div>';
          var bsModal = new bootstrap.Modal(modal);
          bsModal.show();
        });
    });
  });

  if (printBtn) {
    printBtn.addEventListener('click', function() {
      const content = modalBody.querySelector('.transcript-container');
      if (!content) return;
      const win = window.open('', '_blank');
      if (!win) {
        alert('Please allow pop‑ups for printing.');
        return;
      }
      win.document.write('<html><head><title>Transcript</title><style>body { font-family: Arial, sans-serif; padding: 20px; } .watermark-text { display: none; }</style></head><body>');
      win.document.write(content.outerHTML);
      win.document.write('</body></html>');
      win.document.close();
      win.print();
    });
  }
});
</script>

{% endblock %}
