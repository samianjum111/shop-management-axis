{% extends "mobile/base.html" %}
{% block content %}

<!-- Dashboard Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0" style="color:#1a1a2e;">Dashboard</h5>
    <a href="/portal/{{ tenant.schema_name }}/chakki/add/" class="btn btn-sm btn-primary-custom">+ New Order</a>
</div>

<!-- Horizontal Scrollable Analytics Cards -->
<div class="analytics-scroll mb-3" style="overflow-x: auto; white-space: nowrap; padding-bottom: 8px;">
    <div class="d-inline-block me-2" style="min-width: 100px;">
        <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #f0f0f0; background: #fff;">
            <small class="text-muted">Total Orders</small>
            <h6 class="mb-0 fw-bold">{{ pending|add:ready|add:completed }}</h6>
        </div>
    </div>
    <div class="d-inline-block me-2" style="min-width: 100px;">
        <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #fef3e2; background: #fef3e2;">
            <small class="text-muted">Pending</small>
            <h6 class="mb-0 fw-bold text-warning">{{ pending }}</h6>
        </div>
    </div>
    <div class="d-inline-block me-2" style="min-width: 100px;">
        <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #e3f0fd; background: #e3f0fd;">
            <small class="text-muted">Ready</small>
            <h6 class="mb-0 fw-bold text-primary">{{ ready }}</h6>
        </div>
    </div>
    <div class="d-inline-block me-2" style="min-width: 100px;">
        <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #e8f8f0; background: #e8f8f0;">
            <small class="text-muted">Completed</small>
            <h6 class="mb-0 fw-bold text-success">{{ completed }}</h6>
        </div>
    </div>
    <div class="d-inline-block me-2" style="min-width: 100px;">
        <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #f0f0f0; background: #fff;">
            <small class="text-muted">Income</small>
            <h6 class="mb-0 fw-bold">₹{{ total_income|default:"0" }}</h6>
        </div>
    </div>
    <div class="d-inline-block" style="min-width: 100px;">
        <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #f0f0f0; background: #fff;">
            <small class="text-muted">Expenses</small>
            <h6 class="mb-0 fw-bold">₹{{ total_expenses|default:"0" }}</h6>
        </div>
    </div>
</div>

<!-- Quick Actions Grid (3x2) -->
<div class="row g-2 mb-3">
    <div class="col-4">
        <a href="/portal/{{ tenant.schema_name }}/chakki/add/" class="text-decoration-none">
            <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #f0f0f0; background: #fff;">
                <i class="fas fa-plus-circle fa-lg" style="color: #e67e22;"></i>
                <small class="mt-1" style="font-size: 0.7rem;">New Order</small>
            </div>
        </a>
    </div>
    <div class="col-4">
        <a href="/portal/{{ tenant.schema_name }}/chakki/orders/pending/" class="text-decoration-none">
            <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #f0f0f0; background: #fff;">
                <i class="fas fa-clock fa-lg" style="color: #f39c12;"></i>
                <small class="mt-1" style="font-size: 0.7rem;">Pending</small>
            </div>
        </a>
    </div>
    <div class="col-4">
        <a href="/portal/{{ tenant.schema_name }}/chakki/orders/ready/" class="text-decoration-none">
            <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #f0f0f0; background: #fff;">
                <i class="fas fa-hourglass-half fa-lg" style="color: #e67e22;"></i>
                <small class="mt-1" style="font-size: 0.7rem;">Ready</small>
            </div>
        </a>
    </div>
    <div class="col-4">
        <a href="/portal/{{ tenant.schema_name }}/expenses/" class="text-decoration-none">
            <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #f0f0f0; background: #fff;">
                <i class="fas fa-money-bill-wave fa-lg" style="color: #2ecc71;"></i>
                <small class="mt-1" style="font-size: 0.7rem;">Expenses</small>
            </div>
        </a>
    </div>
    <div class="col-4">
        <a href="/portal/{{ tenant.schema_name }}/expenses/add/" class="text-decoration-none">
            <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #f0f0f0; background: #fff;">
                <i class="fas fa-plus fa-lg" style="color: #3498db;"></i>
                <small class="mt-1" style="font-size: 0.7rem;">Add Expense</small>
            </div>
        </a>
    </div>
    <div class="col-4">
        <a href="/portal/{{ tenant.schema_name }}/chakki/settings/" class="text-decoration-none">
            <div class="card p-2 text-center" style="border-radius: 12px; border: 1px solid #f0f0f0; background: #fff;">
                <i class="fas fa-cog fa-lg" style="color: #7f8c8d;"></i>
                <small class="mt-1" style="font-size: 0.7rem;">Settings</small>
            </div>
        </a>
    </div>
</div>

<!-- Recent Orders (compact) -->
<div class="card-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="fw-semibold mb-0">Recent Orders</h6>
        <a href="/portal/{{ tenant.schema_name }}/chakki/orders/pending/" class="text-muted small">See all</a>
    </div>
    <div class="list-group list-group-flush">
        {% for o in recent_orders %}
        <a href="/portal/{{ tenant.schema_name }}/chakki/order/{{ o.id }}/" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0 py-2" style="border-bottom: 1px solid #f0f0f0;">
            <div>
                <span class="fw-semibold">#{{ o.id }}</span>
                <span class="ms-2 text-muted small">{{ o.customer.name|truncatechars:12 }}</span>
                <span class="ms-2 small text-muted">₹{{ o.total_amount }}</span>
            </div>
            <div>
                {% if o.status == 'ready' %}<span class="badge-status ready">Ready</span>
                {% elif o.status == 'completed' %}<span class="badge-status completed">Done</span>
                {% else %}<span class="badge-status pending">Pending</span>{% endif %}
                {% if o.payment_status == 'partial' %}<span class="badge-status partial ms-1">Partial</span>{% endif %}
            </div>
        </a>
        {% empty %}
        <div class="text-center text-muted py-3">No orders yet</div>
        {% endfor %}
    </div>
</div>
{% endblock %}