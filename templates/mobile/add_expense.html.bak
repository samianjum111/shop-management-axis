{% extends "mobile/base.html" %}
{% block title %}Add Expense | {{ tenant.name }}{% endblock %}

{% block extra_head %}
<style>
    .form-section {
        background: var(--surface);
        border-radius: var(--radius);
        padding: 1.25rem 1rem;
        margin-bottom: 1rem;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        transition: background 0.25s, border-color 0.25s;
    }
    .form-section-title {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.5rem;
    }
    .form-section-title i {
        color: var(--accent);
        width: 1.25rem;
        text-align: center;
    }
    .form-group {
        margin-bottom: 0.9rem;
    }
    .form-group label {
        font-weight: 600;
        font-size: 0.8rem;
        color: var(--text-secondary);
        display: block;
        margin-bottom: 0.2rem;
    }
    .form-group .input-group {
        display: flex;
        align-items: center;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        transition: border-color 0.2s, box-shadow 0.2s, background 0.25s;
        overflow: hidden;
    }
    .form-group .input-group:focus-within {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(230,126,34,0.12);
    }
    .form-group .input-group .input-icon {
        padding: 0.5rem 0.6rem 0.5rem 0.8rem;
        color: var(--muted);
        font-size: 0.9rem;
        flex-shrink: 0;
        background: var(--surface-alt);
        border-right: 1px solid var(--border);
        min-width: 2.5rem;
        text-align: center;
    }
    .form-group .input-group input,
    .form-group .input-group select,
    .form-group .input-group textarea {
        width: 100%;
        padding: 0.5rem 0.7rem;
        border: none;
        background: transparent;
        color: var(--text);
        font-size: 0.9rem;
        outline: none;
        min-height: 40px;
    }
    .form-group .input-group textarea {
        min-height: 60px;
        resize: vertical;
    }
    .form-group .input-group select {
        appearance: auto;
        padding-right: 2rem;
    }
    /* Toggle switch for is_credit */
    .toggle-wrapper {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.3rem 0;
    }
    .toggle-wrapper label {
        font-weight: 500;
        font-size: 0.85rem;
        color: var(--text);
        margin: 0;
        cursor: pointer;
    }
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
    }
    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }
    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--border);
        border-radius: 34px;
        transition: 0.3s;
    }
    .toggle-slider:before {
        content: "";
        position: absolute;
        height: 18px;
        width: 18px;
        left: 3px;
        bottom: 3px;
        background: white;
        border-radius: 50%;
        transition: 0.3s;
    }
    .toggle-switch input:checked + .toggle-slider {
        background: var(--accent);
    }
    .toggle-switch input:checked + .toggle-slider:before {
        transform: translateX(20px);
    }
    .btn-save {
        background: var(--gradient-accent);
        color: white;
        border: none;
        padding: 0.7rem 1.5rem;
        border-radius: 2rem;
        font-weight: 600;
        font-size: 0.95rem;
        width: 100%;
        cursor: pointer;
        transition: background 0.15s, transform 0.15s;
        box-shadow: 0 4px 12px rgba(230,126,34,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    .btn-save:hover {
        background: var(--accent-hover);
    }
    .btn-save:active {
        transform: scale(0.97);
    }
    /* Responsive grid for larger screens */
    @media (min-width: 576px) {
        .row-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0 1rem;
        }
        .row-grid .full-width {
            grid-column: 1 / -1;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="form-section">
    <div class="form-section-title">
        <i class="fas fa-plus-circle"></i> Add New Expense / Loan
    </div>

    <form method="post">
        {% csrf_token %}

        <!-- Row 1: Title & Amount -->
        <div class="row-grid">
            <div class="form-group">
                <label for="title"><i class="fas fa-tag" style="color:var(--accent);margin-right:4px;"></i> Title *</label>
                <div class="input-group">
                    <span class="input-icon"><i class="fas fa-pen"></i></span>
                    <input type="text" name="title" id="title" required placeholder="e.g., Medicine, Grocery, Loan to Ali">
                </div>
            </div>
            <div class="form-group">
                <label for="amount"><i class="fas fa-rupee-sign" style="color:var(--accent);margin-right:4px;"></i> Amount (₹) *</label>
                <div class="input-group">
                    <span class="input-icon"><i class="fas fa-coins"></i></span>
                    <input type="number" name="amount" id="amount" step="0.01" required placeholder="0.00">
                </div>
            </div>
        </div>

        <!-- Row 2: Category & Person Name -->
        <div class="row-grid">
            <div class="form-group">
                <label for="category"><i class="fas fa-list" style="color:var(--accent);margin-right:4px;"></i> Category</label>
                <div class="input-group">
                    <span class="input-icon"><i class="fas fa-tags"></i></span>
                    <select name="category" id="category">
                        <option value="general">General</option>
                        <option value="medicine">Medicine</option>
                        <option value="food">Food</option>
                        <option value="utility">Utility</option>
                        <option value="given_loan">Given Loan (Udhaar)</option>
                        <option value="taken_loan">Taken Loan</option>
                        <option value="other">Other</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label for="person_name"><i class="fas fa-user" style="color:var(--accent);margin-right:4px;"></i> Person Name (for loans)</label>
                <div class="input-group">
                    <span class="input-icon"><i class="fas fa-user-circle"></i></span>
                    <input type="text" name="person_name" id="person_name" placeholder="Name of person">
                </div>
            </div>
        </div>

        <!-- Row 3: Phone & Address -->
        <div class="row-grid">
            <div class="form-group">
                <label for="phone"><i class="fas fa-phone" style="color:var(--accent);margin-right:4px;"></i> Phone</label>
                <div class="input-group">
                    <span class="input-icon"><i class="fas fa-phone-alt"></i></span>
                    <input type="text" name="phone" id="phone" placeholder="Contact number">
                </div>
            </div>
            <div class="form-group">
                <label for="address"><i class="fas fa-home" style="color:var(--accent);margin-right:4px;"></i> Address</label>
                <div class="input-group">
                    <span class="input-icon"><i class="fas fa-map-marker-alt"></i></span>
                    <input type="text" name="address" id="address" placeholder="Address (optional)">
                </div>
            </div>
        </div>

        <!-- Row 4: Reason & Due Date -->
        <div class="row-grid">
            <div class="form-group">
                <label for="reason"><i class="fas fa-info-circle" style="color:var(--accent);margin-right:4px;"></i> Reason / Purpose</label>
                <div class="input-group">
                    <span class="input-icon"><i class="fas fa-comment"></i></span>
                    <input type="text" name="reason" id="reason" placeholder="Why this transaction?">
                </div>
            </div>
            <div class="form-group">
                <label for="due_date"><i class="fas fa-calendar-alt" style="color:var(--accent);margin-right:4px;"></i> Due Date</label>
                <div class="input-group">
                    <span class="input-icon"><i class="fas fa-calendar-day"></i></span>
                    <input type="date" name="due_date" id="due_date">
                </div>
            </div>
        </div>

        <!-- Row 5: Notes (full width) -->
        <div class="form-group full-width">
            <label for="notes"><i class="fas fa-sticky-note" style="color:var(--accent);margin-right:4px;"></i> Additional Notes</label>
            <div class="input-group">
                <span class="input-icon"><i class="fas fa-pencil-alt"></i></span>
                <textarea name="notes" id="notes" placeholder="Any extra details" rows="2"></textarea>
            </div>
        </div>

        <!-- Toggle: Credit -->
        <div class="form-group full-width">
            <div class="toggle-wrapper">
                <div class="toggle-switch">
                    <input type="checkbox" name="is_credit" id="is_credit">
                    <span class="toggle-slider"></span>
                </div>
                <label for="is_credit">Money given to someone (receivable)</label>
            </div>
        </div>

        <!-- Save Button -->
        <button type="submit" class="btn-save">
            <i class="fas fa-save"></i> Save Expense
        </button>
    </form>
</div>
{% endblock %}
